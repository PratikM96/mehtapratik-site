---
/**
 * ScopeBox.astro — concept proof. The concept counterpart to ResultBox: a row
 * of SCOPE counts (what was designed and built) plus a rationale line. There
 * is NO testimonial and NO results claim, and the figures stay neutral — orange
 * is reserved for verified client results. Self-initiated work carries scope,
 * never performance. Invent nothing.
 */
type ScopeFigure = { value: string; label: string };
interface Props {
  /** Scope counts (e.g. "5 surfaces", "0→1 brand"). Neutral, no accent. */
  figures: ScopeFigure[];
  /** Why it exists / what it proves — states no results are claimed. */
  rationale: { label: string; text: string };
}
const { figures, rationale } = Astro.props;
---

<div class="cs-result rev">
  <div class="grid">
    {
      figures.map((f) => (
        <div class="r">
          <div class="f">{f.value}</div>
          <div class="l">{f.label}</div>
        </div>
      ))
    }
  </div>
  <div class="cs-rationale">
    <div class="m-label">{rationale.label}</div>
    <p>{rationale.text}</p>
  </div>
</div>

<style>
  .cs-result { border: 1px solid var(--border-strong); border-radius: var(--radius-lg); overflow: hidden; background: var(--surface); }
  .cs-result .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border); }
  .cs-result .r { background: var(--surface); padding: 30px 24px; }
  /* scope figures stay neutral — no accent unit. Orange is for real results only. */
  .cs-result .r .f { font-family: var(--font-display); font-weight: 700; font-size: clamp(32px, 3.8vw, 50px); letter-spacing: -0.025em; line-height: 1; color: var(--text); }
  .cs-result .r .l { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--text-muted); margin-top: 12px; line-height: 1.5; max-width: 24ch; }
  .cs-rationale { padding: 30px 28px; border-top: 1px solid var(--border); }
  .cs-rationale .m-label { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 12px; }
  .cs-rationale p { font-size: 16px; line-height: 1.6; color: var(--text-secondary); max-width: 66ch; }

  @media (max-width: 1100px) { .cs-result .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .cs-result .grid { grid-template-columns: 1fr; } }
</style>
