---
/**
 * About — the practice. Ported verbatim from _reference/about.html.
 * Chrome (default console rail, footer, theme, fonts) comes from Base.astro;
 * shared primitives (.block, .blabel, .signal, .btn, .prose) from global.css.
 * Only page-specific layout (hero, path, principles, tools) is scoped below.
 *
 * ALL body copy is placeholder until Phase 4 (CLAUDE.md). Nothing invented.
 */
import Base from '../layouts/Base.astro';

const CDN = 'https://cdn.mehtapratik.com';
---

<Base
  title="About · Pratik Mehta"
  description="Brand, social, content, UI/UX, motion, and performance, run as one connected practice. I can make the work, understand how it travels, and read what happens after it goes live."
  activeNav="about"
>
  {/* HERO */}
  <section class="ahero">
    <div>
      <div class="k rev">[ About ] · the practice</div>
      <h1 class="rev">I connect the creation of creative with the marketing system that makes it <span class="signal">perform.</span></h1>
      <p class="rev">Brand, social, content, UI/UX, motion, and performance, run as one connected practice. I can make the work, understand how it travels, and read what happens after it goes live.</p>
    </div>
    <figure class="portrait rev"><img src={`${CDN}/about/about-headshot-01.webp`} alt="Pratik Mehta" /></figure>
  </section>

  {/* THE PATH */}
  <section class="block">
    <div class="blabel"><span class="c">[ 01 ]</span><span class="t">The path</span><span class="rule"></span></div>
    <div class="path rev">
      <div class="step"><div class="yr">Foundation</div><div><h3>Engineer</h3><p>A B.S. in Computer Science at NYU. The training never left; it became how brands get built, as systems rather than stacks of separate deliverables.</p></div></div>
      <div class="step"><div class="yr">The turn</div><div><h3>Design</h3><p>Moved toward the audience through design, including building the brand and team for a self-initiated nonprofit from the ground up.</p></div></div>
      <div class="step"><div class="yr">The anchor</div><div><h3>Marketing</h3><p>Marketing kept me there because it made the work accountable to a real person on the other end, not just to taste.</p></div></div>
      <div class="step"><div class="yr">Apr 2024 — present</div><div><h3>Independent creative systems practice</h3><p>An AI-assisted practice building creative, social, and performance as one system. Self-initiated concept work, The Ninth, Level, and WISP, sits alongside the client record and is labeled as such.</p></div></div>
    </div>
  </section>

  {/* HOW I WORK */}
  <section class="block">
    <div class="blabel"><span class="c">[ 02 ]</span><span class="t">How I work</span><span class="rule"></span></div>
    <div class="princ rev">
      <div class="pcard"><div class="n">01</div><h3>Audience first</h3><p>Start with the person on the other end. Everything else is downstream of who it's for.</p></div>
      <div class="pcard"><div class="n">02</div><h3>One system, not silos</h3><p>Brand, content, product, and performance are one connected system, built so the parts reinforce each other.</p></div>
      <div class="pcard"><div class="n">03</div><h3>Build it right once</h3><p>Invest in the engine, not the one-off, so the work scales and keeps running with minimal input.</p></div>
    </div>
  </section>

  {/* TOOLS & AI */}
  <section class="block">
    <div class="blabel"><span class="c">[ 03 ]</span><span class="t">Tools &amp; AI workflow</span><span class="rule"></span></div>
    <div class="prose rev">
      <p><strong>AI is a production advantage, not the identity.</strong> It removes the grunt work between idea and output so more of the time goes into judgment, the part that still has to be human. The work is the point; AI is how it ships faster and at higher volume without losing the system.</p>
    </div>
    <div class="tools rev">
      <span>Brand systems</span><span>Social &amp; content</span><span>UI / UX</span><span>Motion</span><span>Performance</span><span>AI-assisted production</span><span>Design tokens</span><span>Front-end</span>
    </div>
  </section>

  {/* CTA */}
  <section class="block" style="text-align:left">
    <h2 class="about-cta-h">Let's build something that performs.</h2>
    <div class="about-cta-avail">Open to creative or marketing leadership roles · New York</div>
    <div><a class="btn btn-p" href="/contact">Start a conversation</a><a class="btn btn-g" href="/work">See the work</a></div>
  </section>
</Base>

<style>
  /* hero */
  .ahero { padding: 104px 0 64px; display: grid; grid-template-columns: 1.2fr .8fr; gap: 56px; align-items: center; }
  .ahero .k { font-family: var(--font-mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--accent-text); margin-bottom: 22px; }
  .ahero h1 { font-family: var(--font-display); font-weight: 700; font-size: clamp(38px, 5vw, 68px); line-height: .96; letter-spacing: -.03em; }
  .ahero p { font-size: 18px; line-height: 1.5; color: var(--text-secondary); margin-top: 24px; max-width: 56ch; }
  .portrait { border: 1px solid var(--img-frame); border-radius: var(--radius-lg); overflow: hidden; aspect-ratio: 4/5; }
  .portrait img { width: 100%; height: 100%; object-fit: cover; }

  /* prose */
  .prose { max-width: 68ch; }
  .prose p { font-size: 17px; line-height: 1.66; color: var(--text-secondary); margin-bottom: 18px; }
  .prose p strong { color: var(--text); font-weight: 600; }

  /* the path */
  .path { display: flex; flex-direction: column; border-top: 1px solid var(--border); }
  .path .step { display: grid; grid-template-columns: 160px 1fr; gap: 32px; padding: 28px 0; border-bottom: 1px solid var(--border); }
  .path .step .yr { font-family: var(--font-mono); font-size: 12px; letter-spacing: .04em; text-transform: uppercase; color: var(--accent-text); }
  .path .step h3 { font-family: var(--font-display); font-weight: 600; font-size: 22px; letter-spacing: -.02em; margin-bottom: 8px; }
  .path .step p { font-size: 14.5px; line-height: 1.6; color: var(--text-secondary); max-width: 62ch; }

  /* principles */
  .princ { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .pcard { border: 1px solid var(--border); border-radius: var(--radius-lg); background: var(--surface); padding: 28px; min-height: 200px; display: flex; flex-direction: column; }
  .pcard .n { font-family: var(--font-mono); font-size: 11px; letter-spacing: .06em; color: var(--text-muted); }
  .pcard h3 { font-family: var(--font-display); font-weight: 600; font-size: 20px; letter-spacing: -.015em; margin: auto 0 10px; }
  .pcard p { font-size: 13.5px; line-height: 1.55; color: var(--text-secondary); }

  /* tools */
  .tools { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 24px; }
  .tools span { font-family: var(--font-mono); font-size: 11px; letter-spacing: .04em; text-transform: uppercase; color: var(--text-secondary); border: 1px solid var(--border-strong); border-radius: var(--radius-full); padding: 7px 13px; }

  /* cta */
  .about-cta-h { font-family: var(--font-display); font-weight: 700; font-size: clamp(34px, 5vw, 60px); letter-spacing: -.03em; line-height: 1; max-width: 16ch; margin-bottom: 22px; }
  .about-cta-avail { font-family: var(--font-mono); font-size: 11px; letter-spacing: .05em; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 32px; }
  .about-cta-h + .about-cta-avail + div .btn-g { margin-left: 10px; }

  @media (max-width: 1000px) {
    .ahero { grid-template-columns: 1fr; }
    .ahero .portrait { max-width: 340px; }
    .princ { grid-template-columns: 1fr; }
    .path .step { grid-template-columns: 1fr; gap: 8px; }
  }
  @media (max-width: 900px) {
    .ahero { padding: 56px 0 0; }
  }
</style>
