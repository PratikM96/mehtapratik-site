---
/**
 * Home — One System portfolio.
 * Ported from _reference/home-design-v5-converged.html. Chrome (console rail,
 * footer, theme, fonts) lives in Base.astro. Repeated pieces are extracted to
 * components; hero / bento / modules / journal / close stay inline here.
 *
 * ALL body copy is placeholder until Phase 4 (CLAUDE.md). No metrics, clients,
 * roles, or claims are invented; text matches the approved mockup verbatim.
 */
import Base from '../layouts/Base.astro';
import SectionLabel from '../components/SectionLabel.astro';
import DisciplineStrip from '../components/DisciplineStrip.astro';
import WorkIndex from '../components/WorkIndex.astro';

const CDN = 'https://cdn.mehtapratik.com';

---

<Base
  title="Pratik Mehta · Creative & Marketing Strategist"
  description="Creative, social, and performance, built as one system. One connected practice across brand, social, content, UI/UX, motion, and performance."
>
  {/* SPLIT HERO */}
  <section class="hero">
    <div class="hero-inner">
      <div>
        <div class="kick rev">Open to creative or marketing leadership roles · New York</div>
        <h1 class="rev">Creative, social, and performance, built as <span class="signal">one system.</span></h1>
        <p class="lead rev">One connected practice across brand, social, content, UI/UX, motion, and performance, instead of separate hand-offs, and accountable to what the work does after it ships.</p>
        <div class="cta rev"><a class="btn btn-p" href="/work">See the work</a><a class="btn btn-g" href="/contact">Start a conversation</a></div>
      </div>
      <figure class="hero-figure rev">
        <div class="frame"><span class="tagm">Featured · Client</span><img src={`${CDN}/covers/sportime-clubs-cover.webp`} alt="SPORTIME Clubs" /></div>
        <figcaption class="figcap"><span>SPORTIME Clubs · Brand, campaign, motion</span><span>№ 01</span></figcaption>
      </figure>
    </div>
  </section>

  {/* DISCIPLINES STRIP */}
  <DisciplineStrip />

  {/* BENTO — featured */}
  <section class="block" id="featured">
    <SectionLabel code="01" title="Featured" />
    <div class="bento rev">
      <div class="feat-row">
        <a class="tile t-feat" href="/work/sportime-clubs">
          <span class="badge client">Client</span>
          <div class="img"><img src={`${CDN}/covers/sportime-clubs-cover.webp`} alt="SPORTIME Clubs" loading="lazy" /></div>
          <div class="meta">
            <div>
              <h3 class="h3">SPORTIME Clubs</h3>
              <p>Brand and content across tennis and pickleball, and the marketing built around a $75M facility expansion.</p>
            </div>
            <div class="disc">Brand /<br>Campaign /<br>Motion /<br>Photo</div>
          </div>
        </a>
        <a class="tile t-feat" href="/work/the-ninth">
          <span class="badge concept">Concept</span>
          <div class="img"><img src={`${CDN}/covers/the-ninth-cover.webp`} alt="The Ninth" loading="lazy" /></div>
          <div class="meta">
            <div>
              <h3 class="h3">The Ninth</h3>
              <p>A self-initiated esports membership concept, built as one multi-surface product system.</p>
            </div>
            <div class="disc">Brand /<br>UI/UX /<br>AI /<br>Motion</div>
          </div>
        </a>
      </div>
      {/* General practice-level metrics — placeholders until the real numbers come from System Master. Case-study-specific stats live on each case study, not here. */}
      <div class="stat-row">
        <div class="tile t-stat"><div class="fig">00.0</div><div class="lab">General metric · placeholder</div></div>
        <div class="tile t-stat"><div class="fig">00.0</div><div class="lab">General metric · placeholder</div></div>
        <div class="tile t-stat"><div class="fig">00.0</div><div class="lab">General metric · placeholder</div></div>
        <div class="tile t-stat"><div class="fig">00.0</div><div class="lab">General metric · placeholder</div></div>
      </div>
    </div>
  </section>

  {/* WORK INDEX */}
  <WorkIndex />

  {/* MODULES — the practice, documented */}
  <section class="block">
    <SectionLabel code="03" title="The practice, documented" />
    <div class="duo">
      <a class="mod rev" id="brand" href="/brand">
        <div class="k">One System · brand</div>
        <h3 class="h2">The brand, built like a product</h3>
        <p>Tokens, components, voice, and a logo that closes on a single node. A working reference, and a case study of the thinking behind it.</p>
        <span class="go">See the brand system →</span>
      </a>
      <a class="mod mod-about rev" id="about" href="/about">
        <img class="face" src={`${CDN}/about/about-headshot-01.webp`} alt="Pratik Mehta" loading="lazy" />
        <div class="about-body">
          <div class="k">About · the short version</div>
          <h3 class="h2">Engineer turned creative</h3>
          <p>Trained in code, moved to design, kept there by marketing because it made the work accountable to an audience.</p>
          <span class="go">More about the practice →</span>
        </div>
      </a>
    </div>
  </section>

  {/* JOURNAL */}
  <section class="block" id="journal">
    <SectionLabel code="04" title="Journal" />
    <p class="jr-empty rev">Notes on systems, brand, and AI. First posts after launch.</p>
  </section>

  {/* CLOSE */}
  <section class="close" id="contact">
    <div class="rev">
      <h2 class="big">Open to the right role.</h2>
      <div class="avail">Open to creative or marketing leadership roles · New York</div>
      <div class="cta"><a class="btn btn-p" href="mailto:mehtadpratik@gmail.com">Start a conversation</a><a class="btn btn-g" href="/work">See the work</a></div>
    </div>
  </section>
</Base>

<style>
  /* ===== SPLIT HERO ===== */
  .hero { min-height: 100vh; display: flex; align-items: center; padding: 64px 0; }
  .hero-inner { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 56px; align-items: center; width: 100%; }
  .hero-inner > div { display: flex; flex-direction: column; justify-content: center; }
  .hero .kick { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 26px; }
  .hero h1 { font-family: var(--font-display); font-weight: 700; font-size: clamp(38px, 5vw, 68px); line-height: 0.96; letter-spacing: -0.03em; margin: 0; }
  .hero .lead { margin-top: 26px; }
  .hero .cta { margin-top: 36px; display: flex; gap: 12px; flex-wrap: wrap; }
  .hero-figure { position: relative; display: flex; flex-direction: column; }
  /* square (1:1) to host the planned square brand-highlight animation; swap the
     <img> for a <video>/animation when it's ready and the frame already fits */
  .hero-figure .frame { aspect-ratio: var(--ratio-square); border: 1px solid var(--img-frame); border-radius: var(--radius-lg); overflow: hidden; background: var(--surface); }
  .hero-figure .frame img { width: 100%; height: 100%; object-fit: cover; }
  .hero-figure .tagm { position: absolute; top: 16px; left: 16px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; background: var(--accent-fill); color: var(--on-accent); padding: 5px 9px; border-radius: var(--radius-none); }
  .hero-figure .figcap { display: flex; justify-content: space-between; margin-top: 12px; }
  .hero-figure .figcap span { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--text-muted); }

  /* ===== BENTO — two equal feature cards + a general stat strip ===== */
  /* The feature cards teaser the work. The stat strip carries GENERAL practice
     metrics (placeholder until System Master) — not case-study-specific numbers,
     which live on each case study. Features are equal 16:9 so they crop cleanly. */
  .bento { display: flex; flex-direction: column; gap: 16px; }
  .feat-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .stat-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .tile { border: 1px solid var(--border); border-radius: var(--radius-lg); background: var(--surface); overflow: hidden; position: relative; transition: border-color .2s var(--ease-standard); }
  .tile:hover { border-color: var(--border-strong); }

  .t-feat { display: flex; flex-direction: column; }
  .t-feat .img { aspect-ratio: var(--ratio-wide); overflow: hidden; }
  .t-feat .img img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s var(--ease-standard); }
  .t-feat:hover .img img { transform: scale(1.03); }
  .t-feat .meta { padding: 20px; display: flex; justify-content: space-between; align-items: flex-end; gap: 16px; }
  .t-feat .meta p { font-size: 13.5px; color: var(--text-secondary); margin-top: 8px; max-width: 38ch; }
  .t-feat .meta .disc { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); text-align: right; white-space: nowrap; line-height: 1.8; }

  .badge { position: absolute; top: 16px; left: 16px; z-index: 2; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; padding: 4px 8px; border-radius: var(--radius-none); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); }
  .badge.client { background: rgba(255, 90, 31, .16); color: var(--accent-300); border: 1px solid rgba(255, 90, 31, .35); }
  .badge.concept { background: var(--badge-concept-bg); color: var(--badge-concept-tx); border: 1px solid var(--border-strong); }

  .t-stat { padding: 22px; display: flex; flex-direction: column; justify-content: center; gap: 10px; min-height: 132px; }
  .t-stat .fig { font-family: var(--font-display); font-weight: 700; font-size: clamp(28px, 3vw, 42px); line-height: 1; letter-spacing: -0.02em; color: var(--text-muted); }
  .t-stat .lab { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-muted); line-height: 1.5; max-width: 24ch; }

  /* ===== MODULES ===== */
  .duo { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .mod { border: 1px solid var(--border); border-radius: var(--radius-lg); background: var(--surface); padding: 28px; display: flex; flex-direction: column; transition: border-color .2s var(--ease-standard); }
  .mod:hover { border-color: var(--border-strong); }
  .mod .k { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent-text); margin-bottom: 18px; }
  .mod p { font-size: 14px; color: var(--text-secondary); max-width: 46ch; margin-top: 10px; }
  .mod .go { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text); margin-top: auto; padding-top: 22px; }
  /* About module: portrait headshot shown larger and side-by-side, cropped square (in-system) instead of a tiny vertical thumb */
  .mod-about { flex-direction: row; align-items: center; gap: 24px; }
  .mod-about .face { width: 150px; aspect-ratio: var(--ratio-square); height: auto; object-fit: cover; border-radius: var(--radius-md); flex: none; }
  .mod-about .about-body { flex: 1; display: flex; flex-direction: column; }
  @media (max-width: 560px) { .mod-about { flex-direction: column; align-items: flex-start; gap: 18px; } }

  /* ===== JOURNAL ===== */
  .jr-empty { font-size: 16px; color: var(--text-secondary); border-top: 1px solid var(--border); padding-top: 24px; max-width: 52ch; }

  /* ===== CLOSE ===== */
  .close { padding: 110px 0; }
  .close .big { font-family: var(--font-display); font-weight: 700; font-size: clamp(38px, 5.6vw, 68px); line-height: 0.98; letter-spacing: -0.03em; max-width: 14ch; margin-bottom: 22px; }
  .close .avail { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 34px; }
  .close .cta { display: flex; gap: 12px; flex-wrap: wrap; }

  /* ===== responsive ===== */
  @media (max-width: 1100px) {
    .hero { min-height: auto; padding: 48px 0; }
    .hero-inner { grid-template-columns: 1fr; gap: 36px; align-items: start; }
    .hero-inner > div { justify-content: flex-start; }
  }
  @media (max-width: 900px) {
    .duo { grid-template-columns: 1fr; }
    .feat-row { grid-template-columns: 1fr; }
    .stat-row { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .stat-row { grid-template-columns: 1fr; }
  }
</style>
